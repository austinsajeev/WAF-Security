{
  "__inputs": [
    { "name": "DS_PROMETHEUS", "label": "Prometheus", "type": "datasource", "pluginId": "prometheus" }
  ],
  "__requires": [{ "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" }],
  "id": null,
  "uid": "aegisai-security-posture",
  "title": "AegisAI-X — Security Posture",
  "tags": ["aegisai", "security"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1, "type": "stat", "title": "Total Incidents Created",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 5, "color": "yellow" }, { "value": 20, "color": "red" }] } } },
      "targets": [{ "datasource": { "type": "prometheus" }, "expr": "increase(aegisai_incidents_created_total[24h])", "legendFormat": "Incidents/24h" }]
    },
    {
      "id": 2, "type": "stat", "title": "HMAC Events Accepted",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } } },
      "targets": [{ "datasource": { "type": "prometheus" }, "expr": "increase(hmac_accepted_total[5m])", "legendFormat": "Events/5m" }]
    },
    {
      "id": 3, "type": "stat", "title": "Active Blocklist Entries",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 1, "color": "red" }] } } },
      "targets": [{ "datasource": { "type": "prometheus" }, "expr": "aegisai_blocklist_active_entries", "legendFormat": "Blocked IPs" }]
    },
    {
      "id": 4, "type": "stat", "title": "Correlation Engine Alive",
      "gridPos": { "x": 12, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] }, "text": {} },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "mappings": [{ "type": "value", "options": { "1": { "text": "LIVE", "color": "green" } } }], "thresholds": { "steps": [{ "value": 0, "color": "red" }, { "value": 1, "color": "green" }] } } },
      "targets": [{ "datasource": { "type": "prometheus" }, "expr": "aegisai_correlation_worker_up", "legendFormat": "Engine Status" }]
    },
    {
      "id": 5, "type": "stat", "title": "HMAC Events Rejected",
      "gridPos": { "x": 16, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "background", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "value": 0, "color": "green" }, { "value": 1, "color": "red" }] } } },
      "targets": [{ "datasource": { "type": "prometheus" }, "expr": "increase(hmac_rejected_total[5m])", "legendFormat": "Rejected/5m" }]
    },
    {
      "id": 6, "type": "stat", "title": "Blocklist Syncs/min",
      "gridPos": { "x": 20, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "purple" } } },
      "targets": [{ "datasource": { "type": "prometheus" }, "expr": "increase(aegisai_blocklist_synced_total[1m])", "legendFormat": "Syncs/1m" }]
    },
    {
      "id": 7, "type": "timeseries", "title": "Incident Rate by Severity",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "targets": [
        { "datasource": { "type": "prometheus" }, "expr": "increase(aegisai_incidents_created_total{severity=\"CRITICAL\"}[5m])", "legendFormat": "CRITICAL" },
        { "datasource": { "type": "prometheus" }, "expr": "increase(aegisai_incidents_created_total{severity=\"HIGH\"}[5m])", "legendFormat": "HIGH" },
        { "datasource": { "type": "prometheus" }, "expr": "increase(aegisai_incidents_created_total{severity=\"MEDIUM\"}[5m])", "legendFormat": "MEDIUM" }
      ]
    },
    {
      "id": 8, "type": "timeseries", "title": "HMAC Worker Throughput",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "targets": [
        { "datasource": { "type": "prometheus" }, "expr": "rate(hmac_accepted_total[1m]) * 60", "legendFormat": "Accepted/min" },
        { "datasource": { "type": "prometheus" }, "expr": "rate(hmac_rejected_total[1m]) * 60", "legendFormat": "Rejected/min" }
      ]
    },
    {
      "id": 9, "type": "timeseries", "title": "Correlation Engine Poll Duration",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 7 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } },
      "targets": [{ "datasource": { "type": "prometheus" }, "expr": "histogram_quantile(0.95, rate(aegisai_correlation_poll_duration_seconds_bucket[5m]))", "legendFormat": "p95 latency" }]
    },
    {
      "id": 10, "type": "timeseries", "title": "Blocklist Activity",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 7 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": { "defaults": { "custom": { "lineWidth": 2, "fillOpacity": 10 } } },
      "targets": [
        { "datasource": { "type": "prometheus" }, "expr": "increase(aegisai_blocklist_synced_total[5m])", "legendFormat": "IPs Synced/5m" },
        { "datasource": { "type": "prometheus" }, "expr": "increase(aegisai_blocklist_removed_total[5m])", "legendFormat": "IPs Removed/5m" },
        { "datasource": { "type": "prometheus" }, "expr": "aegisai_blocklist_active_entries", "legendFormat": "Active Blocks" }
      ]
    }
  ]
}
