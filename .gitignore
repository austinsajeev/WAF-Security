# =============================================================================
# AegisAI-X — .gitignore
# Security-sensitive and local files are excluded from version control.
# =============================================================================

# ----- SECRETS & CREDENTIALS (NEVER COMMIT) ----------------------------------
.env
*.env
.env.*
!.env.example          # keep the template safe to share
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
secrets.yml
secrets.yaml
secrets.json
*_secret*
*secret*
*credentials*
*password*

# ----- LOG FILES -------------------------------------------------------------
*.log
ch_logs.txt
ch_logs_utf8.txt
clickhouse.log
corr_logs.txt
err.log
ps_output.txt
logs/
log/

# ----- OS / EDITOR JUNK ------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*.swo
*~

# ----- PYTHON ----------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
venv/
.venv/
env/
ENV/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ----- NODE / JS -------------------------------------------------------------
node_modules/
.npm
.yarn/
dist/
.next/
.nuxt/

# ----- DOCKER LOCAL DATA -----------------------------------------------------
data/
volumes/
*.tar.gz
*.tar

# ----- MISC ------------------------------------------------------------------
*.bak
*.tmp
*.zip
